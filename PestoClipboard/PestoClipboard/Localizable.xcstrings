    "When enabled, items copied from 1Password, Bitwarden, LastPass, and other password managers will not be saved." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quan s'activa, els elements copiats de 1Password, Bitwarden, LastPass i altres gestors de contrasenyes no es desaran."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når aktiveret, vil elementer kopieret fra 1Password, Bitwarden, LastPass og andre adgangskodeadministratorer ikke blive gemt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden Elemente, die aus 1Password, Bitwarden, LastPass und anderen Passwort-Managern kopiert wurden, nicht gespeichert."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, items copied from 1Password, Bitwarden, LastPass, and other password managers will not be saved."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está habilitado, los elementos copiados de 1Password, Bitwarden, LastPass y otros gestores de contraseñas no se guardarán."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque activé, les éléments copiés depuis 1Password, Bitwarden, LastPass et autres gestionnaires de mots de passe ne seront pas enregistrés."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सक्षम होने पर, 1Password, Bitwarden, LastPass और अन्य पासवर्ड प्रबंधकों से कॉपी किए गए आइटम सहेजे नहीं जाएंगे।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika diaktifkan, item yang disalin dari 1Password, Bitwarden, LastPass, dan pengelola kata sandi lainnya tidak akan disimpan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando abilitato, gli elementi copiati da 1Password, Bitwarden, LastPass e altri gestori password non verranno salvati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、1Password、Bitwarden、LastPassなどのパスワードマネージャーからコピーした項目は保存されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 1Password, Bitwarden, LastPass 및 기타 암호 관리자에서 복사한 항목이 저장되지 않습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indien ingeschakeld, worden items die van 1Password, Bitwarden, LastPass en andere wachtwoordbeheerders zijn gekopieerd, niet opgeslagen."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При включении элементы, скопированные из 1Password, Bitwarden, LastPass и других менеджеров паролей, не будут сохранены."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "När aktiverat sparas inte objekt som kopierats från 1Password, Bitwarden, LastPass och andra lösenordshanterare."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，从 1Password、Bitwarden、LastPass 和其他密码管理器复制的项目将不会保存。"
          }
        }
      }
    },
    "When enabled, items copied on other Macs or iOS devices via Universal Clipboard will not be saved." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quan s'activa, els elements copiats en altres Macs o dispositius iOS mitjançant el porta-retalls universal no es desaran."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når aktiveret, vil elementer kopieret på andre Macs eller iOS-enheder via Universal Udklipsholder ikke blive gemt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden Elemente, die auf anderen Macs oder iOS-Geräten über die universelle Zwischenablage kopiert wurden, nicht gespeichert."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, items copied on other Macs or iOS devices via Universal Clipboard will not be saved."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está habilitado, los elementos copiados en otros Macs o dispositivos iOS a través del Portapapeles Universal no se guardarán."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque activé, les éléments copiés sur d'autres Macs ou appareils iOS via le Presse-papiers universel ne seront pas enregistrés."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सक्षम होने पर, यूनिवर्सल क्लिपबोर्ड के माध्यम से अन्य Macs या iOS उपकरणों पर कॉपी किए गए आइटम सहेजे नहीं जाएंगे।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika diaktifkan, item yang disalin di Mac atau perangkat iOS lain melalui Universal Clipboard tidak akan disimpan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando abilitato, gli elementi copiati su altri Mac o dispositivi iOS tramite Appunti Universali non verranno salvati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、ユニバーサルクリップボード経由で他のMacやiOSデバイスでコピーした項目は保存されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 유니버설 클립보드를 통해 다른 Mac 또는 iOS 기기에서 복사한 항목이 저장되지 않습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
