    "Choose a keyboard shortcut to quickly open your clipboard history from anywhere." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tria una drecera de teclat per obrir ràpidament l'historial del porta-retalls."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg en tastaturgenvej for hurtigt at åbne udklipsholderhistorikken."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle ein Tastenkürzel, um den Zwischenablageverlauf schnell von überall zu öffnen."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose a keyboard shortcut to quickly open your clipboard history from anywhere."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige un atajo de teclado para abrir rápidamente el historial del portapapeles desde cualquier lugar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez un raccourci clavier pour ouvrir rapidement l'historique du presse-papiers."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कहीं से भी क्लिपबोर्ड इतिहास खोलने के लिए कीबोर्ड शॉर्टकट चुनें।"
          }
        },
        "id" : {
          "stringUnit" : {
